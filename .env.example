APP_NAME="Agentic Software Development Team"
DATABASE_URL="sqlite:///./agent_team.db"
GENERATED_PROJECTS_DIR="generated_projects"
MAX_PARALLEL_RUNS=5
MAX_REVISION_PASSES=2

# Default local LLM provider.
LLM_PROVIDER="ollama"
LLM_MODEL="qwen2.5-coder"
OLLAMA_BASE_URL="http://localhost:11434"

# Optional cloud providers. Mission Control detects these automatically.
# Do not hardcode real keys in source or commit them to git.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Dashboard talks to the FastAPI backend through this URL.
MISSION_CONTROL_API_URL="http://localhost:8000"
